<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CoInnova × Columbia — ENV-INTEL MVP</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0D0F14;
    --paper: #F4F1EB;
    --mist: #E8E4DC;
    --accent: #1A4D3A;
    --accent2: #2E7D55;
    --gold: #C8A84B;
    --mid: #6B7280;
    --light-ink: #3D4147;
    --rule: rgba(13,15,20,0.12);
    --slide-w: 1200px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #1A1C22; font-family: 'DM Sans', sans-serif; color: var(--ink); cursor: default; }

/* ── LANG TOGGLE ── */
.lang-toggle {
display: flex; align-items: center; gap: 0;
border: 1px solid rgba(255,255,255,0.15); overflow: hidden;
}
.lang-btn {
background: none; border: none; color: rgba(255,255,255,0.4);
font-family: ‘Space Mono’, monospace; font-size: 11px;
padding: 6px 14px; cursor: pointer;
letter-spacing: 0.1em; transition: all 0.2s;
}
.lang-btn.active { background: var(–gold); color: var(–ink); font-weight: 700; }
.lang-btn:hover:not(.active) { color: rgba(255,255,255,0.8); }
.lang-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.15); }

/* toggle visibility */
[data-lang] { display: none; }
body.lang-pt [data-lang=“pt”] { display: revert; }
body.lang-en [data-lang=“en”] { display: revert; }
/* for inline elements */
span[data-lang], div[data-lang], em[data-lang] { display: none; }
body.lang-pt span[data-lang=“pt”],
body.lang-pt div[data-lang=“pt”],
body.lang-pt em[data-lang=“pt”]  { display: inline; }
body.lang-en span[data-lang=“en”],
body.lang-en div[data-lang=“en”],
body.lang-en em[data-lang=“en”]  { display: inline; }
/* block-level */
p[data-lang], h2[data-lang], h4[data-lang], ul[data-lang], table[data-lang] { display: none; }
body.lang-pt p[data-lang=“pt”],
body.lang-pt h2[data-lang=“pt”],
body.lang-pt h4[data-lang=“pt”],
body.lang-pt ul[data-lang=“pt”],
body.lang-pt table[data-lang=“pt”]  { display: revert; }
body.lang-en p[data-lang=“en”],
body.lang-en h2[data-lang=“en”],
body.lang-en h4[data-lang=“en”],
body.lang-en ul[data-lang=“en”],
body.lang-en table[data-lang=“en”]  { display: revert; }

/* ── NAV ── */
.nav-bar {
position: fixed; top: 0; left: 0; right: 0; z-index: 100;
background: rgba(26,28,34,0.97);
backdrop-filter: blur(12px);
display: flex; align-items: center; justify-content: space-between;
padding: 0 48px; height: 58px;
border-bottom: 1px solid rgba(255,255,255,0.07);
}
.nav-left { display: flex; align-items: center; gap: 24px; }
.nav-logo { color: #fff; font-family: ‘Space Mono’, monospace; font-size: 13px; letter-spacing: 0.08em; }
.nav-logo span { color: var(–gold); }
.nav-right { display: flex; align-items: center; gap: 20px; }
.nav-counter { color: rgba(255,255,255,0.35); font-family: ‘Space Mono’, monospace; font-size: 11px; }
.nav-progress { position: fixed; top: 57px; left: 0; right: 0; z-index: 99; height: 3px; background: rgba(255,255,255,0.05); }
.nav-progress-fill { height: 100%; background: linear-gradient(90deg, var(–accent2), var(–gold)); width: 0%; transition: width 0.4s cubic-bezier(.4,0,.2,1); }

/* ── DECK ── */
.deck { padding: 58px 0 80px; }
.slide {
max-width: var(–slide-w); margin: 0 auto 4px;
background: var(–paper); min-height: 675px;
position: relative; overflow: hidden;
display: none; animation: slideIn 0.45s cubic-bezier(.4,0,.2,1);
}
.slide.active { display: flex; flex-direction: column; }
@keyframes slideIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.slide-num { position: absolute; top: 36px; right: 44px; font-family: ‘Space Mono’, monospace; font-size: 11px; color: var(–mid); letter-spacing: 0.1em; }

/* ── COVER ── */
#s1 { background: var(–ink); flex-direction: column; justify-content: flex-end; padding: 72px 80px; min-height: 675px; }
#s1::before { content: ‘’; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 85% 20%, rgba(46,125,85,0.18) 0%, transparent 65%), radial-gradient(ellipse 50% 40% at 10% 80%, rgba(200,168,75,0.08) 0%, transparent 60%); }
.cover-grid { position: absolute; inset: 0; pointer-events: none; background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 80px 80px; }
.cover-eyebrow { font-family: ‘Space Mono’, monospace; font-size: 11px; color: var(–gold); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 28px; }
.cover-title { font-family: ‘DM Serif Display’, serif; font-size: clamp(40px, 5vw, 64px); color: #fff; line-height: 1.05; max-width: 680px; margin-bottom: 12px; }
.cover-title em { color: var(–gold); font-style: normal; }
.cover-sub { font-size: 16px; color: rgba(255,255,255,0.45); font-weight: 300; margin-bottom: 60px; max-width: 520px; line-height: 1.6; }
.cover-meta { display: flex; gap: 48px; align-items: flex-end; }
.cover-meta-label { font-family: ‘Space Mono’, monospace; font-size: 9px; color: rgba(255,255,255,0.3); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 5px; }
.cover-meta-value { font-size: 14px; color: rgba(255,255,255,0.75); font-weight: 500; }

/* ── INNER ── */
.slide-inner { padding: 64px 80px; flex: 1; display: flex; flex-direction: column; }
.section-label { font-family: ‘Space Mono’, monospace; font-size: 10px; color: var(–accent2); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 10px; }
.slide-title { font-family: ‘DM Serif Display’, serif; font-size: clamp(28px, 3vw, 40px); color: var(–ink); line-height: 1.15; margin-bottom: 8px; }
.slide-title em { color: var(–accent); font-style: italic; }
.slide-lead { font-size: 15px; color: var(–mid); line-height: 1.7; max-width: 700px; margin-bottom: 36px; font-weight: 300; }

/* ── PROBLEM CARDS ── */
.problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 8px; }
.problem-card { background: #fff; border: 1px solid var(–mist); padding: 22px 24px; border-left: 3px solid var(–ink); }
.problem-card h4 { font-size: 13px; font-weight: 600; color: var(–ink); margin-bottom: 6px; }
.problem-card p { font-size: 13px; color: var(–mid); line-height: 1.55; font-weight: 300; }

/* ── FEATURE LIST ── */
.feature-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
.feature-list li { display: flex; align-items: flex-start; gap: 16px; padding: 16px 20px; background: #fff; border: 1px solid var(–mist); }
.feat-icon { width: 32px; height: 32px; flex-shrink: 0; background: var(–ink); color: #fff; display: flex; align-items: center; justify-content: center; font-family: ‘Space Mono’, monospace; font-size: 11px; }
.feat-body h4 { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
.feat-body p { font-size: 13px; color: var(–mid); line-height: 1.5; font-weight: 300; }

/* ── TABLE ── */
.data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.data-table thead tr { background: var(–ink); color: #fff; }
.data-table thead th { padding: 12px 18px; text-align: left; font-weight: 500; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
.data-table tbody tr { border-bottom: 1px solid var(–mist); }
.data-table tbody tr:last-child { border-bottom: none; }
.data-table td { padding: 14px 18px; color: var(–light-ink); font-weight: 300; vertical-align: top; }
.data-table td:first-child { font-weight: 600; color: var(–ink); }
.data-table tbody tr:nth-child(even) td { background: rgba(0,0,0,0.018); }
.risk-row td:last-child { color: var(–accent2) !important; font-weight: 400 !important; }
.ms-highlight td { background: rgba(26,77,58,0.06) !important; }
.ms-highlight td:first-child { color: var(–accent) !important; }

/* ── TIMELINE ── */
.timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
.timeline::before { content: ‘’; position: absolute; left: 20px; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(–accent), var(–mist)); }
.tl-item { display: flex; gap: 24px; align-items: flex-start; padding: 16px 0; position: relative; }
.tl-dot { width: 42px; height: 42px; flex-shrink: 0; background: var(–ink); color: #fff; display: flex; align-items: center; justify-content: center; font-family: ‘Space Mono’, monospace; font-size: 10px; font-weight: 700; position: relative; z-index: 1; }
.tl-dot.highlight { background: var(–accent2); }
.tl-content h4 { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.tl-content p { font-size: 13px; color: var(–mid); line-height: 1.5; font-weight: 300; }
.tl-badge { display: inline-block; margin-left: 8px; background: var(–gold); color: var(–ink); font-size: 10px; padding: 2px 8px; font-weight: 600; font-family: ‘Space Mono’, monospace; }

/* ── INVEST ── */
.invest-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.invest-card { background: #fff; border: 1px solid var(–mist); padding: 24px; display: flex; flex-direction: column; gap: 8px; }
.invest-card.total { background: var(–ink); color: #fff; grid-column: 1/-1; flex-direction: row; align-items: center; justify-content: space-between; padding: 28px 32px; }
.invest-label { font-size: 11px; color: var(–mid); font-family: ‘Space Mono’, monospace; letter-spacing: 0.08em; text-transform: uppercase; }
.invest-value { font-family: ‘DM Serif Display’, serif; font-size: 28px; color: var(–ink); }
.invest-sub { font-size: 12px; color: var(–mid); font-weight: 300; }
.invest-card.total .invest-label { color: rgba(255,255,255,0.4); }
.invest-card.total .invest-value { font-size: 36px; color: var(–gold); }
.invest-card.total .invest-sub { color: rgba(255,255,255,0.5); }

/* ── IP OPTIONS ── */
.ip-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.ip-card { background: #fff; border: 1px solid var(–mist); padding: 28px 24px; display: flex; flex-direction: column; gap: 10px; }
.ip-card.featured { background: var(–ink); border-color: var(–ink); }
.ip-tag { font-family: ‘Space Mono’, monospace; font-size: 10px; background: var(–mist); color: var(–accent); padding: 4px 10px; display: inline-block; letter-spacing: 0.12em; width: fit-content; }
.ip-card.featured .ip-tag { background: var(–accent2); color: #fff; }
.ip-card h3 { font-family: ‘DM Serif Display’, serif; font-size: 22px; color: var(–ink); }
.ip-card.featured h3 { color: #fff; }
.ip-card p { font-size: 13px; color: var(–mid); line-height: 1.6; font-weight: 300; }
.ip-card.featured p { color: rgba(255,255,255,0.55); }

/* ── OP COST ── */
.op-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
.op-card { background: #fff; border: 1px solid var(–mist); padding: 24px; display: flex; flex-direction: column; gap: 6px; }
.op-card.highlight-green { border-left: 3px solid var(–accent2); }
.op-label { font-size: 11px; font-family: ‘Space Mono’, monospace; color: var(–mid); letter-spacing: 0.08em; text-transform: uppercase; }
.op-value { font-family: ‘DM Serif Display’, serif; font-size: 30px; color: var(–ink); }
.op-annual { font-size: 12px; color: var(–mid); font-weight: 300; }

/* ── OOS LIST ── */
.oos-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.oos-list li { display: flex; gap: 14px; align-items: flex-start; padding: 14px 18px; background: #fff; border: 1px solid var(–mist); border-left: 3px solid var(–mist); }
.oos-phase { font-family: ‘Space Mono’, monospace; font-size: 10px; color: var(–mid); white-space: nowrap; padding-top: 2px; min-width: 68px; }
.oos-text { font-size: 13px; color: var(–light-ink); font-weight: 300; line-height: 1.5; }
.oos-text strong { color: var(–ink); font-weight: 600; }

/* ── QUOTE ── */
.quote-block { border-left: 3px solid var(–gold); padding: 16px 20px; background: rgba(200,168,75,0.06); margin-top: 24px; }
.quote-block p { font-family: ‘DM Serif Display’, serif; font-size: 15px; color: var(–light-ink); line-height: 1.6; font-style: italic; }
.quote-block cite { font-size: 11px; color: var(–mid); font-family: ‘Space Mono’, monospace; margin-top: 8px; display: block; }

/* ── ROADMAP ── */
.roadmap-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
.roadmap-item { display: flex; gap: 20px; align-items: flex-start; padding: 18px 22px; background: #fff; border: 1px solid var(–mist); }
.roadmap-week { font-family: ‘Space Mono’, monospace; font-size: 10px; color: var(–accent2); min-width: 80px; padding-top: 2px; }
.roadmap-body h4 { font-size: 13px; font-weight: 600; margin-bottom: 3px; color: var(–ink); }
.roadmap-body p { font-size: 13px; color: var(–mid); font-weight: 300; line-height: 1.5; }
.cta-banner { background: var(–accent); color: #fff; padding: 20px 28px; display: flex; align-items: center; justify-content: space-between; margin-top: 20px; }
.cta-banner span { font-family: ‘DM Serif Display’, serif; font-size: 22px; }
.cta-banner small { font-size: 12px; color: rgba(255,255,255,0.6); font-family: ‘Space Mono’, monospace; }

/* ── ABOUT / LAST SLIDE ── */
#s13 { background: var(–ink); justify-content: center; align-items: center; text-align: center; padding: 80px; min-height: 675px; }
#s13::before { content: ‘’; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(46,125,85,0.15) 0%, transparent 70%); }
.about-eyebrow { font-family: ‘Space Mono’, monospace; font-size: 11px; color: var(–gold); letter-spacing: 0.2em; margin-bottom: 24px; position: relative; }
.about-title { font-family: ‘DM Serif Display’, serif; font-size: 48px; color: #fff; margin-bottom: 12px; position: relative; }
.about-sub { font-size: 15px; color: rgba(255,255,255,0.4); font-weight: 300; margin-bottom: 48px; line-height: 1.7; max-width: 640px; position: relative; }
.about-chips { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; margin-bottom: 48px; }
.about-chip { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); padding: 10px 20px; font-size: 13px; color: rgba(255,255,255,0.7); }
.about-footer { font-size: 11px; color: rgba(255,255,255,0.2); font-family: ‘Space Mono’, monospace; position: relative; }

/* ── NAV BUTTONS ── */
.slide-nav { max-width: var(–slide-w); margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 20px 0; }
.btn-nav { background: none; border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.6); padding: 10px 28px; font-family: ‘Space Mono’, monospace; font-size: 11px; letter-spacing: 0.1em; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
.btn-nav:hover { border-color: var(–gold); color: var(–gold); }
.btn-nav:disabled { opacity: 0.2; cursor: not-allowed; }
.slide-dots { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; max-width: 500px; }
.dot { width: 28px; height: 3px; background: rgba(255,255,255,0.15); cursor: pointer; transition: background 0.2s; }
.dot.active { background: var(–gold); }
.dot:hover:not(.active) { background: rgba(255,255,255,0.4); }

/* ── BAR CHART ── */
.bar-chart { display: flex; gap: 10px; align-items: flex-end; height: 88px; padding: 0 4px; margin-top: 16px; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 5px; }
.bar-fill { width: 100%; }
.bar-label { font-size: 9px; font-family: ‘Space Mono’, monospace; color: var(–mid); }

@media (max-width: 900px) {
.slide-inner { padding: 40px 32px; }
.problem-grid, .invest-grid, .ip-grid, .op-grid { grid-template-columns: 1fr; }
.invest-card.total { flex-direction: column; }
.cover-meta { flex-direction: column; gap: 20px; }
#s1 { padding: 48px 32px; }
.cover-title { font-size: 36px; }
.nav-bar { padding: 0 20px; }
}
</style>

</head>
